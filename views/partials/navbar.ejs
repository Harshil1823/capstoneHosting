    /* Styling for the logo and brand text */
    .navbar-brand {
        font-size: 1.5rem;
    }
  
    .navbar img {
        height: 40px;
        margin-right: 10px;
    }
  
    /* Navbar link styles */
    .navbar-nav .nav-link {
        font-size: 1.1rem;
        padding: 8px 15px;
    }
  
    .navbar-nav .nav-link:hover {
        background-color: rgba(255, 255, 255, 0.1); /* Original subtle hover */
    }   
    /* Flexbox spacing adjustments */
    .container {
        display: flex;
        justify-content: space-between; /* Push left and right sections apart */
        align-items: center;
    }
  
    /* Ensures navbar links align right when collapsed */
