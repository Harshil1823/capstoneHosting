<nav class="navbar navbar-expand-lg" style="background-color: #110777;">
    <div class="container d-flex justify-content-between align-items-center">
        <!-- Left: Logo and Task Manager -->
        <% if (currentUser) { %>
            <a href="/tasks" class="d-flex align-items-center text-decoration-none">
                <img src="/images/logo.png" alt="Task Manager Logo" style="height: 40px; margin-right: 10px;">
                <span class="navbar-brand text-white fw-bold mb-0">Task Manager</span>
            </a>
        <% } else { %>
            <a href="/" class="d-flex align-items-center text-decoration-none">
                <img src="/images/logo.png" alt="Task Manager Logo" style="height: 40px; margin-right: 10px;">
                <span class="navbar-brand text-white fw-bold mb-0">Task Manager</span>
            </a>
        <% } %>

        <!-- Right: Navbar links -->
        <% if (currentUser) { %>
        <!-- Show these links ONLY when user is logged in -->
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="/tasks" style="transition: 0.3s;">Index</a>
                <a class="nav-link text-white" href="/tasks/new" style="transition: 0.3s;">New Task</a>
            </div>
        </div>
        <% } else { %>
        <!-- Show these links ONLY when user is NOT logged in -->
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" href="/login" style="transition: 0.3s;">Login</a>
                <a class="nav-link text-white" href="/register" style="transition: 0.3s;">Sign Up</a>
            </div>
        </div>
        <% } %>

        <!-- Mobile Toggle (show only when there are links) -->
