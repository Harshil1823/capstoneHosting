<% layout('layouts/boilerplate') %>
 
<!-- Link to the dashboard CSS file -->
<link rel="stylesheet" href="/css/dashboard.css">
 
<div class="container-fluid">
  <div class="row">
    <% if (currentUser) { %>
    <div class="col-md-3">
      <!-- Include the user panel partial -->
      <%- include('../partials/user_panel') %>
    </div>
    <div class="col-md-6">
      <div class="dashboard-container">
        <!-- Debug Statement -->
        <!-- <pre><%=// JSON.stringify(analytics, null, 2) %></pre>
 
        <!-- Task Summary Cards -->
        <div class="summary-cards">
          <div class="card">
            <h3>Completed Tasks</h3>
            <p>
              <% if (analytics && analytics.dailyStats && typeof analytics.dailyStats.tasksCompleted !== 'undefined') { %>
                <%= analytics.dailyStats.tasksCompleted %>
              <% } else { %>
                Error: Data missing
              <% } %>
            </p>
          </div>
 
          <div class="card">
            <h3>Pending Tasks</h3>
            <p>
              <% if (analytics && analytics.dailyStats && typeof analytics.dailyStats.tasksUpdated !== 'undefined') { %>
                <%= analytics.dailyStats.tasksUpdated %>
              <% } else { %>
                Error: Data missing
              <% } %>
            </p>
          </div>
 
          <div class="card">
            <h3>Overdue Tasks</h3>
            <p>
              <% if (analytics && analytics.dailyStats && typeof analytics.dailyStats.tasksOverdue !== 'undefined') { %>
                <%= analytics.dailyStats.tasksOverdue %>
              <% } else { %>
                Error: Data missing
              <% } %>
            </p>
          </div>
        </div>
 
        <!-- Analytics Views -->
        <div class="analytics-sections">
          <% if (analytics) { %>
            <%- include('../analytics/company_overview.ejs', { analytics }) %>
            <%- include('../analytics/department_stats.ejs', { departmentAnalytics: analytics.departmentStats || [] }) %>
            <%- include('../analytics/task_priority.ejs', { priorityAnalytics: analytics.priorityStats || [] }) %>
            <%- include('../analytics/user_performance.ejs', { userAnalytics: analytics.userStats || [] }) %>
          <% } else { %>
            <p>Error: No analytics data available.</p>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>