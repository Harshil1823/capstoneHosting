<% layout('layouts/boilerplate') %>
<%- include('../partials/user_panel') %>
<%- include('../partials/info_panel') %>

<link rel="stylesheet" href="/css/profilestyles.css">
<div class="profile-container">
    <div class="profile-header">
      <div class="profile-image">
        <img src="<%= user.profilePicture || '/images/deafult-user.jpg' %>" alt="Profile Picture">
      </div>
      <h1 class="profile-name"><%= user.firstName %> <%= user.lastName %></h1>
      <p class="profile-username">@<%= user.username %></p>
    </div>
  
    <div class="profile-details">
      <div class="detail-row">
        <span class="detail-label">Company Name:</span>
        <span class="detail-value"><%= user.companyName %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Work Email:</span>
        <span class="detail-value"><%= user.workEmail %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Role:</span>
        <span class="detail-value"><%= user.role %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Tasks:</span>
        <span class="detail-value"><%= user.tasks.length > 0 ? user.tasks.length : 'None' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Departments:</span>
        <span class="detail-value"><%= user.departments.length > 0 ? user.departments.length : 'None' %></span>
      </div>
    </div>
  </div>