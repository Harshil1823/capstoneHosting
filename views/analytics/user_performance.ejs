<div class="user-performance">
    <h2>User Performance Metrics</h2>
    <table>
        <thead>
            <tr>
                <th>User</th>
                <th>Tasks Created</th>
                <th>Tasks Completed</th>
            </tr>
        </thead>
        <tbody>
            <% if (userAnalytics && userAnalytics.length > 0) { %>
                <% userAnalytics.forEach(user => { %>
                    <tr>
                        <td><%= user.user.username %></td>
                        <td><%= user.tasksCreated %></td>
                        <td><%= user.tasksCompleted %></td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="3">Error: No user performance data available.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
